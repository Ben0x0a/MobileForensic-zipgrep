# Generated by Cargo
# will have compiled files and executables
debug/
target/
tasks/

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Generated by cargo mutants
# Contains mutation testing data
**/mutants.out*/

# Cargo lock
# Keep Cargo.lock for binaries/applications.
# Uncomment the next line only for libraries if you intentionally do not want to commit it.
# Cargo.lock


# ---------------------------------------------------------------------------
# OS-specific artifacts
# ---------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
.fseventsd

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*


# ---------------------------------------------------------------------------
# IDEs and editors
# ---------------------------------------------------------------------------

# RustRover / JetBrains
# JetBrains specific template is maintained in a separate JetBrains.gitignore that can
# be found at https://github.com/github/gitignore/blob/main/Global/JetBrains.gitignore
# and can be added to the global gitignore or merged into this file.
.idea/

# VS Code
.vscode/

# Vim
*.swp
*.swo
*.swn

# Sublime Text
*.sublime-workspace
*.sublime-project


# Claude Code / Anthropic
.claude/


# OpenAI / Codex-style local configs
.openai/
.codex/

# GitHub Copilot local workspace/config artifacts
.github/copilot-instructions.local.md

# Gemini / Google AI tooling
.gemini/

# Generic AI scratch/output folders
.ai/
.llm/
.llms/
.prompts.local/
.chatgpt/

# Local planning notes (not part of the published project)
docs/roadmap.md
ROADMAP.local.md
